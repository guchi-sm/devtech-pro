# ─── SERVER ───────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ─── CORS ─────────────────────────────────────────────────────────────
CLIENT_ORIGIN=https://your-app.vercel.app

# ─── DATABASE ─────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?appName=Cluster0

# ─── AUTH ─────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_64_byte_hex_secret

# Generate hash: node -e "require('bcryptjs').hash('your_password',12).then(console.log)"
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=$2a$12$<bcrypt_hash_of_your_password>

# ─── EMAIL (Resend) ────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx
OWNER_EMAIL=you@yourdomain.com

# ─── EMAIL (SMTP fallback) ─────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=you@gmail.com
EMAIL_PASS=your_gmail_app_password

# ─── AI ────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxx
GEMINI_API_KEY=your_gemini_key

# ─── MPESA (Tuma) ──────────────────────────────────────────────────────
MPESA_STK_PROVIDER=tuma
MPESA_STK_BASE_URL=https://api.tuma.co.ke
MPESA_STK_API_KEY=tuma_xxxxxxxxxxxx
MPESA_STK_EMAIL=you@gmail.com
MPESA_CALLBACK_URL=https://your-api.onrender.com/api/payments/webhook/mpesa-stk
